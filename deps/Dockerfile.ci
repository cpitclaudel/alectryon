# syntax=docker/dockerfile:1
ARG PYTHON_VERSION
FROM python:${PYTHON_VERSION}

ARG OCAML_VERSION
ARG ROCQ_VERSION
ARG PIP_CMP

## APT

ENV DEBIAN_FRONTEND=noninteractive

RUN <<EOF
  apt-get update
  apt-get install -y --no-install-recommends \
    build-essential curl \
    m4 libgmp-dev zlib1g-dev pkg-config \
    emacs-nox
  rm -rf /var/lib/apt/lists/*
EOF

## OPAM

RUN <<EOF
  curl -sSfL -o /usr/local/bin/opam \
    https://github.com/ocaml/opam/releases/download/2.5.0/opam-2.5.0-x86_64-linux
  chmod +x /usr/local/bin/opam
EOF

## Python

COPY deps/requirements.dev /tmp/requirements.dev
RUN <<EOF
  grep '=' /tmp/requirements.dev | sed "s/==/$PIP_CMP/" \
    | env -u PIP_CMP pip install --no-cache-dir -q -r /dev/stdin
EOF

## Rocq

COPY deps/opam.sh /tmp/opam.sh
RUN <<EOF
  opam init --bare --auto-setup --disable-sandboxing
  bash /tmp/opam.sh "$OCAML_VERSION" --switch rocq --rocq-version "$ROCQ_VERSION"
EOF

ENV CI=true
