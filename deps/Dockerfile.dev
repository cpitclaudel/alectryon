# syntax=docker/dockerfile:1
FROM python:3.14

ARG UID
ARG GID

ARG OPAM_SWITCH
ARG OCAML_VERSION
ARG ROCQ_VERSION
ARG EASYCRYPT_VERSION

## APT

ENV DEBIAN_FRONTEND=noninteractive

RUN <<EOF
  apt-get update
  apt-get install -y --no-install-recommends \
    build-essential curl git rsync unzip \
    m4 libgmp-dev zlib1g-dev pkg-config \
    cmake libuv1-dev ccache \
    nodejs npm \
    emacs-nox \
    texlive-xetex texlive-luatex latexmk \
    texlive-fonts-recommended texlive-latex-extra texlive-extra-utils \
    fonts-linuxlibertine fonts-firacode
  rm -rf /var/lib/apt/lists/*
EOF

## OPAM

RUN <<EOF
  curl -sSfL -o /usr/local/bin/opam \
    https://github.com/ocaml/opam/releases/download/2.5.0/opam-2.5.0-x86_64-linux
  chmod +x /usr/local/bin/opam
EOF

## Python

COPY deps/requirements.dev /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# User setup

RUN groupadd -g "$GID" docker
RUN useradd -m -u "$UID" -g "$GID" --create-home --shell /bin/bash docker

USER docker
WORKDIR /home/docker

## Dafny

RUN <<EOF
  curl -sSfL https://github.com/dafny-lang/dafny/releases/download/v4.11.0/dafny-4.11.0-x64-ubuntu-22.04.zip -o /tmp/dafny.zip
  unzip -q /tmp/dafny.zip -d /home/docker
  rm /tmp/dafny.zip
EOF

## OPAM

COPY --chown=docker:docker deps/opam.sh /tmp/opam.sh
RUN <<EOF
  opam init --bare --auto-setup --disable-sandboxing
  bash /tmp/opam.sh "$OCAML_VERSION" --switch "$OPAM_SWITCH" \
    --rocq-version "$ROCQ_VERSION" --easycrypt-version "$EASYCRYPT_VERSION"
EOF

## Lean 3

RUN <<EOF
  curl -sSfL https://github.com/leanprover-community/lean/releases/download/v3.51.1/lean-3.51.1-linux.tar.gz -o /tmp/lean3.tar.gz
  tar xzf /tmp/lean3.tar.gz -C /home/docker/
  rm /tmp/lean3.tar.gz
EOF

## Lean 4 (via elan)

RUN <<EOF
  curl -sSfL https://raw.githubusercontent.com/leanprover/elan/v4.2.1/elan-init.sh \
    | sh -s -- -y --no-modify-path --default-toolchain leanprover/lean4:v4.28.0
  /home/docker/.elan/bin/lean --version
EOF

## Symlinks

RUN <<EOF
  mkdir -p /home/docker/.local/bin/
  ln -s /home/docker/dafny/dafny /home/docker/.local/bin/dafny
  ln -s /home/docker/lean-3.51.1-linux/bin/lean /home/docker/.local/bin/lean3
EOF

## Path

ENV CI=true
ENV PYTHON_VENV=/usr/local
ENV PATH="/home/docker/.elan/bin:/home/docker/dafny:/home/docker/.local/bin/:${PATH}"
ENV COLORTERM=truecolor
